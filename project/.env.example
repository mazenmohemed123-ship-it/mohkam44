VITE_SUPABASE_URL=your_supabase_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
VITE_PAYMOB_IFRAME_ID=your_iframe_id_here

# Firebase Cloud Messaging (push notifications). Leave blank to disable push.
# Get these from Firebase Console > Project Settings > General > Your Web App.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
# Web Push certificate "Key pair" from Firebase Console > Cloud Messaging > Web configuration
VITE_FIREBASE_VAPID_KEY=

# Optional legacy Web Push (used only as a fallback when Firebase is not configured)
VITE_VAPID_PUBLIC_KEY=

# --- Supabase Edge Function secrets (set with the Supabase dashboard / CLI, NOT here) ---
# HF_TOKEN=                 # Hugging Face access token for the ai-tools function
# FCM_SERVICE_ACCOUNT=      # Firebase service account JSON (single line) for send-notification
# PAYMOB_API_KEY=           # Paymob live API key
# PAYMOB_HMAC_SECRET=       # Paymob HMAC secret (webhook verification)
# PAYMOB_INTEGRATION_ID=    # Paymob integration id
# PAYMOB_IFRAME_ID=         # Paymob iframe id
